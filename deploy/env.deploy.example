# Generated by setup.sh — do not commit deploy/.env (contains secrets).

# Public access
PUBLIC_HOST=192.168.1.10
HTTP_PORT=80
GATEWAY_PORT=8080

# Demo / data
LOAD_DEMO_DATA=true
IHRIS_USE_DEMO_DATA=true

# Application
APP_NAME=MoH-PMS
APP_ENV=production
APP_DEBUG=false
APP_URL=http://192.168.1.10
APP_KEY=
JWT_SECRET=

# Admin (seeded when LOAD_DEMO_DATA=true or on first seed)
ADMIN_EMAIL=admin@moh.go.ug
ADMIN_PASSWORD=Demo@Moh2026!
ADMIN_NAME="PMS Administrator"

# Database
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=moh_pms
MYSQL_USER=pms
MYSQL_PASSWORD=change_me_pms

# Expose data services on host (optional)
EXPOSE_MYSQL=false
EXPOSE_REDIS=false
MYSQL_HOST_PORT=3307
REDIS_HOST_PORT=6379

# Frontend build
VITE_API_BASE_URL=/api/v1

# Host nginx (when INSTALL_HOST_NGINX=true)
INSTALL_HOST_NGINX=false
SERVER_NAME=_
